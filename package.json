{
  "name": "rclone-manager",
  "version": "0.2.8",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "tauri": "tauri",
    "dev:portable": "npm run tauri dev -- --features portable",
    "dev:flatpak": "npm run tauri dev -- --features flatpak",
    "dev:headless": "npm run tauri dev -- --config src-tauri/tauri.conf.headless.json --features web-server,tray -- --no-default-features",
    "build:portable": "npm run tauri build -- --features portable --no-bundle",
    "build:flatpak": "npm run tauri build -- --bundles deb --config '{\"bundle\":{\"createUpdaterArtifacts\":false}}' --features flatpak",
    "build:snap": "npm run tauri build -- --bundles deb && cp src-tauri/target/release/bundle/deb/rclone-manager_*.deb ./rclone-manager.deb && snapcraft",
    "build:headless": "npm run tauri build -- --config src-tauri/tauri.conf.headless.json --features web-server,tray -- --no-default-features",
    "lint": "eslint \"**/*.{ts,html}\" && cd src-tauri && cargo clippy -- -D warnings",
    "format": "prettier --write \"**/*.{ts,html,scss,json}\" && cd src-tauri && cargo fmt",
    "fix:all": "node scripts/fix-svg-ids.cjs && npm run format && eslint --fix \"**/*.{ts,html}\"",
    "audit:i18n": "node scripts/audit-i18n-keys.cjs",
    "sync:flags": "node scripts/update-flags.cjs",
    "sync:providers": "node scripts/update-providers.cjs",
    "sync:endpoints": "node scripts/update-endpoints.cjs",
    "prepare": "husky"
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "^22.0.2",
    "@angular/common": "^22.0.3",
    "@angular/compiler": "^22.0.3",
    "@angular/core": "^22.0.3",
    "@angular/forms": "^22.0.3",
    "@angular/material": "^22.0.2",
    "@angular/platform-browser": "^22.0.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/lang-sass": "^6.0.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.4",
    "@codemirror/legacy-modes": "^6.5.3",
    "@codemirror/state": "^6.7.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.3",
    "@ngx-translate/core": "^18.0.0",
    "@ngx-translate/http-loader": "^18.0.0",
    "@tauri-apps/api": "~2.11.1",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-os": "^2.3.2",
    "codemirror": "^6.0.2",
    "cronstrue": "^3.21.0",
    "marked": "^18.0.5",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^22.0.4",
    "@angular/cli": "^22.0.4",
    "@angular/compiler-cli": "^22.0.3",
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2.11.3",
    "@types/jasmine": "~6.0.0",
    "angular-eslint": "22.0.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "husky": "^9.1.7",
    "jasmine-core": "~6.3.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.2.0",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0"
  },
  "lint-staged": {
    "**/*.{ts,html}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{scss,json}": [
      "prettier --write"
    ],
    "src-tauri/**/*.rs": [
      "sh -c 'cd src-tauri && cargo fmt'",
      "sh -c 'cd src-tauri && cargo clippy -- -D warnings'"
    ]
  }
}
